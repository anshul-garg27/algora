# Copy to .env and fill in. run.sh auto-loads .env if ANTHROPIC_API_KEY isn't already exported.
ANTHROPIC_API_KEY=sk-ant-...

# --- Models (Opus 4.8 is the default) ---
# DEFAULT_MODEL=opus             # opus | sonnet | haiku
# MODEL_OPUS=claude-opus-4-8
# MODEL_SONNET=claude-sonnet-4-6
# MODEL_HAIKU=claude-haiku-4-5-20251001
# ADAPTIVE_THINKING_MODELS=opus-4-8,opus-4-9  # model-id substrings that use adaptive thinking

# --- 1M context + web search ---
# ENABLE_1M_CONTEXT=1            # 1M-context beta header for Opus
# CONTEXT_1M_BETA=context-1m-2025-08-07
# ENABLE_WEB_SEARCH=1            # server-side web search tool (Anthropic-hosted)
# WEB_SEARCH_MAX_USES=5

# --- Per-mode generation budgets (max_tokens / thinking budget / effort) ---
# ASSESS_MAX_TOKENS=16000        ASSESS_THINKING_BUDGET=8000     ASSESS_EFFORT=xhigh
# INTERVIEW_MAX_TOKENS=32000     INTERVIEW_THINKING_BUDGET=12000 INTERVIEW_EFFORT=xhigh
# LLD_MAX_TOKENS=128000          LLD_THINKING_BUDGET=16000       LLD_EFFORT=xhigh
# HLD_MAX_TOKENS=128000          HLD_THINKING_BUDGET=16000       HLD_EFFORT=xhigh
# Effort values for adaptive (Opus) models: low|medium|high|xhigh|max

# --- Tool execution + server ---
# MAX_AGENT_STEPS=20
# DEFAULT_EXEC_TIMEOUT=15
# MAX_EXEC_TIMEOUT=60
# PORT=8000
# HTTPS=1                        # serve HTTPS (needed for the mic on iPhone); HTTPS=0 for plain HTTP
